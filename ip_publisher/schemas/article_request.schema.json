{
  "$id": "article_request.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "product",
    "kb_scope",
    "seo",
    "platforms",
    "audience",
    "language",
    "content_type",
    "structure",
    "publish"
  ],
  "properties": {
    "task_id": { "type": "string" },
    "product": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "kb_scope": {
      "type": "object",
      "properties": {
        "doc_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "seo": {
      "type": "object",
      "required": ["primary_keywords"],
      "properties": {
        "primary_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "secondary_keywords": {
          "type": "array",
          "items": { "type": "string" }
        },
        "forbidden_terms": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "hotspot": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "outline": {
      "type": "object",
      "properties": {
        "brief": { "type": "string" },
        "must_include_sections": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "platforms": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "wechat_official",
          "xiaohongshu",
          "zhihu",
          "juejin",
          "csdn",
          "toutiao",
          "weibo"
        ]
      }
    },
    "audience": { "type": "string" },
    "tone": { "type": "string" },
    "content_type": {
      "type": "string",
      "enum": ["general", "technical"]
    },
    "structure": {
      "type": "object",
      "required": [
        "qa_required",
        "comparison_table_required",
        "ai_friendly_required",
        "authority_signal_required",
        "entity_labels_required",
        "opening_value_required",
        "code_example_required"
      ],
      "properties": {
        "qa_required": { "type": "boolean" },
        "comparison_table_required": { "type": "boolean" },
        "ai_friendly_required": { "type": "boolean" },
        "authority_signal_required": { "type": "boolean" },
        "entity_labels_required": { "type": "boolean" },
        "opening_value_required": { "type": "boolean" },
        "code_example_required": { "type": "boolean" }
      }
    },
    "publish": {
      "type": "object",
      "required": ["mode", "publisher"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["publish_pack", "direct_publish_ready"]
        },
        "publisher": {
          "type": "string",
          "enum": ["none", "wechatsync"]
        }
      }
    },
    "language": {
      "type": "string",
      "enum": ["zh-CN"]
    }
  }
}
